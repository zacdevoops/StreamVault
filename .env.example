# Ads runtime mode: test | production
EXPO_PUBLIC_ADS_MODE=test

# Android ads master switch (default: enabled on Android)
EXPO_PUBLIC_ADS_ANDROID_ENABLED=true

# AdMob App ID (Android) — use Google test ID in development
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713

# AdMob ad unit IDs (Android production)
EXPO_PUBLIC_ADMOB_BANNER_HOME_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_SEARCH_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=

# iOS (prepared for future rollout — not enabled in app yet)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
