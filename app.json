{
  "expo": {
    "name": "StreamVault",
    "slug": "streamvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "streamvault",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.streamvault.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "NSLocalNetworkUsageDescription": "StreamVault connects to your local backend server to load video streams during development.",
        "NSCameraUsageDescription": null,
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "processing"
        ]
      }
    },
    "android": {
      "package": "com.streamvault.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F32F30"
      },
      "permissions": [
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "ios": true,
            "android": true
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "./plugins/withAndroidMediaNotificationLaunch.js",
      "./plugins/withAndroidVideoPiPExitFix.js",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F32F30",
          "image": "./assets/images/icon.png",
          "imageWidth": 120
        }
      ],
      "expo-sqlite",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAnalytics",
              "RNFBRemoteConfig"
            ]
          }
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
